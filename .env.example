# Application
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]
SECRET_KEY=replace-with-a-long-random-value

# AI providers
OPENROUTER_API_KEY=

# Infrastructure
DATABASE_URL=postgresql+asyncpg://norma:norma@postgres:5432/norma
REDIS_URL=redis://redis:6379/0
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Docker Compose database bootstrap
POSTGRES_DB=norma
POSTGRES_USER=norma
POSTGRES_PASSWORD=norma
