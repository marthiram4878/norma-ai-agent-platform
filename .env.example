# Application
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]
SECRET_KEY=replace-with-a-long-random-value
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# AI providers
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.5-flash

# Infrastructure
DATABASE_URL=postgresql+asyncpg://norma:norma@postgres:5432/norma
REDIS_URL=redis://redis:6379/0
LAUNCH_STRATEGY_QUEUE=norma:jobs:launch_strategy
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=norma_knowledge
EMBEDDING_SERVICE_URL=http://embeddings:8001
EMBEDDING_MODEL=BAAI/bge-m3

# Notion OAuth (Phase 5)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/api/v1/integrations/notion/callback

# GitHub OAuth (Phase 5)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/integrations/github/callback
FRONTEND_ORIGIN=http://localhost:5173

# Docker Compose database bootstrap
POSTGRES_DB=norma
POSTGRES_USER=norma
POSTGRES_PASSWORD=norma
